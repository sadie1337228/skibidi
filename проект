@dp.message(F.text == "Удалить все")
async def delete_all(message: types.Message):
    if message.from_user.id in reminders:
        for r in reminders[message.from_user.id]:
            job_id = f"{message.from_user.id}_{r['time'].timestamp()}"
            try:
                scheduler.remove_job(job_id)
            except:
                pass
        reminders[message.from_user.id] = []
    await message.answer("Все напоминания удалены", reply_markup=main_kb)

@dp.message()
async def handle_text(message: types.Message):
    if hasattr(dp, "state") and dp.state.get("user") == message.from_user.id:
        if dp.state.get("action") == "remind":
            text = message.text
            seconds = dp.state["seconds"]
            remind_time = add_reminder(message.from_user.id, text, seconds)
            scheduler.add_job(
                send_reminder,
                "date",
                run_date=remind_time,
                args=[bot, message.from_user.id, text],
                id=f"{message.from_user.id}_{remind_time.timestamp()}"
            )
            await message.answer(f"Напомню через {seconds//60} минут: {text}", reply_markup=main_kb)
            dp.state = {}
        
        elif dp.state.get("action") == "waiting_email":
            email = message.text.strip()
            if "@" in email and "." in email:
                user_reminders = reminders.get(message.from_user.id, [])
                result = await send_email_tasks(email, user_reminders)
                await message.answer(result, reply_markup=main_kb)
            else:
                await message.answer("Неверный email. Попробуйте ещё:")
                return
            dp.state = {}

@dp.inline_query()
async def inline_handler(query: types.InlineQuery):
    if not query.query:
        results = [InlineQueryResultArticle(
            id="help",
            title="Быстрое напоминание",
            input_message_content=InputTextMessageContent(message_text="Пример: @bot 30 Позвонить маме")
        )]
        await query.answer(results, cache_time=1)
        return
    
    result = await create_inline_reminder(query.query, query.from_user.id)
    await query.answer([result], cache_time=1)

