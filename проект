# Отправка письма
async def send_email_tasks(user_email, tasks_list):
    if not tasks_list:
        return "Нет активных напоминаний"
    
    message = "ВАШИ НАПОМИНАНИЯ\n\n"
    for i, task in enumerate(tasks_list, 1):
        message += f"{i}. {task['text']}\n   Время: {task['time'].strftime('%d.%m %H:%M')}\n\n"
    
    msg = EmailMessage()
    msg.set_content(message)
    msg["Subject"] = "Ваши напоминания"
    msg["From"] = EMAIL
    msg["To"] = user_email
    
    loop = asyncio.get_event_loop()
    await loop.run_in_executor(None, lambda: _send_sync(msg))
    return "Отправлено на почту!"

def _send_sync(msg):
    with smtplib.SMTP("smtp.gmail.com", 587) as server:
        server.starttls()
        server.login(EMAIL, EMAIL_PASSWORD)
        server.send_message(msg)

# Отправка напоминания
async def send_reminder(bot: Bot, user_id, text):
    await bot.send_message(user_id, f"НАПОМИНАНИЕ: {text}")

def add_reminder(user_id, text, seconds):
    remind_time = datetime.now() + timedelta(seconds=seconds)
    if user_id not in reminders:
        reminders[user_id] = []
    reminders[user_id].append({"text": text, "time": remind_time})
    return remind_time

# Ежедневное сообщение
async def daily_message(bot: Bot):
    for user_id in reminders.keys():
        await bot.send_message(user_id, "Доброе утро! Запланируйте дела на сегодня.")

# Inline режим
async def create_inline_reminder(query_text, user_id):
    parts = query_text.split(maxsplit=1)
    if len(parts) != 2 or not parts[0].isdigit():
        return InlineQueryResultArticle(
            id="0",
            title="Ошибка формата",
            input_message_content=InputTextMessageContent(
                message_text="Пример: @bot 30 Купить хлеб (напомнит через 30 минут)"
            )
        )
    
    minutes = int(parts[0])
    text = parts[1]
    if minutes > 1440:
        minutes = 1440
    
    remind_time = add_reminder(user_id, text, minutes * 60)
    scheduler.add_job(
        send_reminder,
        "date",
        run_date=remind_time,
        args=[bot, user_id, text],
        id=f"{user_id}_{remind_time.timestamp()}"
    )
    
    return InlineQueryResultArticle(
        id="1",
        title=f"Напомнить через {minutes} минут",
        input_message_content=InputTextMessageContent(message_text=f"Напомню через {minutes} минут: {text}")
    )

